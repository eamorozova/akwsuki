# режим данных: bitbucket (боевой) | local (демо-фикстуры)
DATA_MODE=bitbucket

# Bitbucket HTTP access token (Bearer)
BITBUCKET_TOKEN=

# проверка TLS по умолчанию ВЫКЛЮЧЕНА (самоподписанные сертификаты); включить:
# BITBUCKET_TLS_REJECT=1

# порт бэкенда (фронт через Vite проксирует на него; по умолчанию 3001)
# PORT=3001
